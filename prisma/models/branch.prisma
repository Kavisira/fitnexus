model Branch {
  id             String       @id @default(cuid())
  branchCode     String       @unique
  organizationId String

  branchName     String
  displayName    String?
  email          String?
  phone          String?
  logo           String?

  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  latitude       Decimal?
  longitude      Decimal?

  isHeadOffice   Boolean      @default(false)
  status         RecordStatus @default(ACTIVE)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      String?
  updatedBy      String?

  organization   Organization @relation(fields: [organizationId], references: [id])
  users UserBranch[]
  @@unique([organizationId, branchName])
  @@index([organizationId])
  @@index([branchCode])
}