model VerificationOtp {
  id          String        @id @default(cuid())
  targetType  OtpTargetType
  targetValue String
  otpCode     String
  purpose     OtpPurpose
  status      OtpStatus     @default(PENDING)

  expiresAt   DateTime
  verifiedAt  DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([targetType, targetValue])
  @@index([purpose])
  @@index([status])
  @@index([expiresAt])
}