model Organization {
  id               String       @id @default(cuid())
  organizationCode String       @unique
  organizationName String
  displayName      String
  email            String       @unique
  phone            String       @unique
  website          String?
  status           RecordStatus @default(ACTIVE)

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  createdBy        String?
  updatedBy        String?
  branches         Branch[]
  settings OrganizationSettings? 
  roles Role[]
  users User[]
}